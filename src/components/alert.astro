---
interface Props {
  variant?: "default" | "destructive"
  class?: string
}

const { variant = "default", class: className } = Astro.props
---

<div
  data-slot="alert"
  role="alert"
  class={`grid gap-0.5 rounded-none border px-2.5 py-2 text-left text-xs has-[>svg]:grid-cols-[auto_1fr] has-[>svg]:gap-x-2 w-full relative group/alert ${
    variant === "destructive"
      ? "text-destructive bg-card"
      : "bg-card text-card-foreground"
  } ${className || ""}`}
>
  <slot />
</div>

<style>
  [data-slot="alert"] svg {
    grid-row: span 2;
    translate: 0;
    color: currentColor;
  }

  [data-slot="alert"] :global(svg:not([class*="size-"])) {
    width: 1rem;
    height: 1rem;
  }
</style>